{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run backend: debugpy 5678",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "debugpy",
        "--listen",
        "127.0.0.1:5678",
        "--wait-for-client",
        "-m",
        "uvicorn",
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Check backend health",
      "type": "shell",
      "command": "curl.exe",
      "args": [
        "-f",
        "http://127.0.0.1:8000/health"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}